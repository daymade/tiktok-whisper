# TikTok Whisper API Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# API Configuration
# =============================================================================
# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8081
ENVIRONMENT=development

# CORS configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# Database Configuration
# =============================================================================
# Primary database (SQLite or PostgreSQL)
DB_TYPE=sqlite
DB_PATH=./data/tiktok-whisper.db

# PostgreSQL configuration (if DB_TYPE=postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-database-password
DB_NAME=postgres
DB_SSL_MODE=disable

# pgvector configuration (for embeddings)
PGVECTOR_HOST=localhost
PGVECTOR_PORT=5432
PGVECTOR_USER=postgres
PGVECTOR_PASSWORD=your-pgvector-password
PGVECTOR_DBNAME=postgres
PGVECTOR_SSL_MODE=disable

# =============================================================================
# External Service APIs
# =============================================================================
# OpenAI API (for Whisper and embeddings)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_ORG_ID=org-your-org-id-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Google Gemini API (for embeddings)
GEMINI_API_KEY=AIza-your-gemini-api-key-here

# ElevenLabs API (for Speech-to-Text)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# =============================================================================
# Storage Configuration
# =============================================================================
# MinIO/S3 Storage (for file uploads)
ENABLE_MINIO=false
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=tiktok-whisper
MINIO_USE_SSL=false
MINIO_REGION=us-east-1

# AWS S3 (alternative to MinIO)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# =============================================================================
# Redis Configuration
# =============================================================================
# Redis (for job queue and caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10

# Alternative Redis URL format
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# JWT Configuration
# =============================================================================
# JWT Secret (for authentication)
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production
JWT_ISSUER=tiktok-whisper
JWT_AUDIENCE=tiktok-whisper-api
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=168h

# =============================================================================
# Whisper Provider Configuration
# =============================================================================
# Local whisper.cpp configuration
WHISPER_CPP_ENABLED=true
WHISPER_CPP_BINARY_PATH=/path/to/whisper.cpp/main
WHISPER_CPP_MODEL_PATH=/path/to/whisper.cpp/models/ggml-large-v2.bin
WHISPER_CPP_LANGUAGE=zh
WHISPER_CPP_MODEL=large

# OpenAI Whisper configuration
OPENAI_WHISPER_ENABLED=true
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_WHISPER_RESPONSE_FORMAT=text

# ElevenLabs configuration
ELEVENLABS_ENABLED=false
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_LANGUAGE=zh

# =============================================================================
# Provider Framework Configuration
# =============================================================================
# Default provider
DEFAULT_PROVIDER=whisper_cpp

# Provider settings
PROVIDER_TIMEOUT=300
PROVIDER_MAX_CONCURRENCY=2
PROVIDER_FALLBACK_CHAIN=whisper_cpp,openai,elevenlabs

# =============================================================================
# Logging and Monitoring
# =============================================================================
# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Log format (json, text)
LOG_FORMAT=text

# Enable request logging
ENABLE_REQUEST_LOGGING=true

# Enable metrics collection
ENABLE_METRICS=true

# Metrics port (for Prometheus)
METRICS_PORT=9090

# =============================================================================
# Rate Limiting
# =============================================================================
# Rate limiting configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=10

# =============================================================================
# Security
# =============================================================================
# Security settings
CORS_ENABLED=true
CORS_MAX_AGE=86400
CORS_ALLOW_CREDENTIALS=true

# Enable HTTPS
ENABLE_HTTPS=false
HTTPS_CERT_FILE=
HTTPS_KEY_FILE=

# API key authentication
API_KEY_AUTH_ENABLED=false
API_KEY_HEADER=X-API-Key

# =============================================================================
# Email Configuration (for notifications)
# =============================================================================
# SMTP settings
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=TikTok Whisper <noreply@tiktok-whisper.com>

# =============================================================================
# Analytics
# =============================================================================
# Analytics tracking
ENABLE_ANALYTICS=false
ANALYTICS_PROVIDER=segment
ANALYTICS_WRITE_KEY=your-segment-write-key

# =============================================================================
# Testing Configuration
# =============================================================================
# Test mode settings
TEST_MODE=false
TEST_DATA_PATH=./test/data

# Mock external services in tests
MOCK_EXTERNAL_SERVICES=false

# =============================================================================
# Feature Flags
# =============================================================================
# Feature toggles
ENABLE_DUAL_EMBEDDINGS=true
ENABLE_WEB_INTERFACE=true
ENABLE_BATCH_PROCESSING=true
ENABLE_AUTO_RETRIES=true
ENABLE_HEALTH_CHECKS=true
ENABLE_SWAGGER_UI=true

# =============================================================================
# Performance Tuning
# =============================================================================
# Performance settings
MAX_UPLOAD_SIZE=100MB
MAX_CONCURRENT_UPLOADS=5
MAX_CONCURRENT_TRANSCRIPTIONS=10
CACHE_TTL=300s
WORKER_POOL_SIZE=10

# =============================================================================
# Deployment Configuration
# =============================================================================
# Docker/Kubernetes
POD_NAME=
POD_NAMESPACE=
INSTANCE_ID=

# Cloud provider (aws, gcp, azure, local)
CLOUD_PROVIDER=local

# Region/zone
CLOUD_REGION=us-east-1
CLOUD_ZONE=us-east-1a